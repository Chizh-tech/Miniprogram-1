.page {
  background: linear-gradient(180deg, #062f57 0%, #0a517b 32%, #14829b 100%);
  min-height: 100vh;
  padding-bottom: 160rpx;
  position: relative;
}

.ocean-shine {
  position: absolute;
  left: -60rpx;
  top: 100rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(168, 244, 255, 0.32), rgba(168, 244, 255, 0));
}

/* 头部英雄区域 */
.hero-header {
  background: linear-gradient(135deg, rgba(14, 139, 179, 0.95), rgba(14, 101, 176, 0.95));
  padding: 36rpx 32rpx 40rpx;
}

.hero-date {
  margin-bottom: 20rpx;
}

.hero-date-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.meta-chip {
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #fff;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-chip {
  border: 1rpx solid transparent;
}

.status-chip.status-want {
  color: #2092d1;
  background: #e8f7ff;
  border-color: #2092d1;
}

.status-chip.status-depart {
  color: #d4861e;
  background: #fff4dd;
  border-color: #d4861e;
}

.status-chip.status-diving {
  color: #2f9a63;
  background: #e9f7ef;
  border-color: #2f9a63;
}

.status-chip.status-return {
  color: #9256c9;
  background: #f7ecff;
  border-color: #9256c9;
}

.hero-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

/* 日记内容 */
.content-section {
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.diary-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #123b57;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.diary-content {
  display: block;
  font-size: 30rpx;
  color: #1a4c67;
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 媒体区域 */
.media-section {
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #123b57;
}

/* 图片网格 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  width: calc((100% - 24rpx) / 3);
  aspect-ratio: 1;
  border-radius: 10rpx;
  object-fit: cover;
}

.image-item.single {
  width: 100%;
  max-height: 600rpx;
  aspect-ratio: unset;
  height: 400rpx;
}

/* 视频列表 */
.video-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.video-item {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 420rpx;
  background-color: #000;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 32rpx;
  background: rgba(5, 34, 60, 0.95);
  box-shadow: 0 -2rpx 18rpx rgba(0, 0, 0, 0.22);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 22rpx 0;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-share {
  background-color: rgba(255, 255, 255, 0.14);
  color: #d7efff;
}

.btn-edit {
  background: linear-gradient(90deg, #1aa5c5, #0d7db8);
  color: #fff;
}

.btn-delete {
  background-color: #ffe2dc;
  color: #d8563d;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  color: #ccc;
  font-size: 28rpx;
}
