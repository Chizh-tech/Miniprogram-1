.page {
  background-color: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 头部英雄区域 */
.hero-header {
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  padding: 36rpx 32rpx 40rpx;
}

.hero-date {
  margin-bottom: 20rpx;
}

.hero-date-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.meta-chip {
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #fff;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

/* 日记内容 */
.content-section {
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.diary-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.diary-content {
  display: block;
  font-size: 30rpx;
  color: #444;
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 媒体区域 */
.media-section {
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* 图片网格 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item {
  width: calc((100% - 24rpx) / 3);
  aspect-ratio: 1;
  border-radius: 10rpx;
  object-fit: cover;
}

.image-item.single {
  width: 100%;
  max-height: 600rpx;
  aspect-ratio: unset;
  height: 400rpx;
}

/* 视频列表 */
.video-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.video-item {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.video-player {
  width: 100%;
  height: 420rpx;
  background-color: #000;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 22rpx 0;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-share {
  background-color: #F5F5F5;
  color: #555;
}

.btn-edit {
  background-color: #4A90E2;
  color: #fff;
}

.btn-delete {
  background-color: #FFF0F0;
  color: #E25454;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  color: #ccc;
  font-size: 28rpx;
}
