.page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 顶部工具栏 */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: #4A90E2;
}

.view-tabs {
  display: flex;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  overflow: hidden;
}

.tab-item {
  padding: 12rpx 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background-color: #fff;
  color: #4A90E2;
  font-weight: 500;
  border-radius: 24rpx;
}

.create-btn {
  padding: 14rpx 28rpx;
  background-color: #fff;
  color: #4A90E2;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 日历容器 */
.calendar-container {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 月份导航 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #4A90E2;
  font-weight: 300;
}

.month-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.today-btn {
  font-size: 22rpx;
  color: #4A90E2;
  border: 1rpx solid #4A90E2;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: normal;
}

/* 星期表头 */
.week-header {
  display: flex;
  margin-bottom: 12rpx;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0;
}

/* 日期格子 */
.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 50%;
}

.day-cell.empty {
  pointer-events: none;
}

.day-num {
  font-size: 28rpx;
  color: #333;
  line-height: 1.2;
}

.day-cell.today .day-num {
  color: #4A90E2;
  font-weight: 700;
}

.day-cell.today {
  background-color: #EEF4FE;
  border-radius: 50%;
}

.day-cell.selected {
  background-color: #4A90E2;
  border-radius: 50%;
}

.day-cell.selected .day-num {
  color: #fff;
  font-weight: 700;
}

.day-cell.has-diary .day-num {
  color: #4A90E2;
}

.diary-dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #4A90E2;
  border-radius: 50%;
  margin-top: 4rpx;
}

.day-cell.selected .diary-dot {
  background-color: #fff;
}

.month-summary {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

/* 日记列表区域 */
.diary-section {
  padding: 0 24rpx;
}

.section-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 日记卡片 */
.diary-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.diary-card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.diary-date-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  min-width: 80rpx;
  background: #EEF4FE;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-right: 20rpx;
}

.diary-day {
  font-size: 36rpx;
  font-weight: 700;
  color: #4A90E2;
  line-height: 1.1;
}

.diary-month-year {
  font-size: 20rpx;
  color: #999;
  margin-top: 2rpx;
}

.diary-meta {
  flex: 1;
}

.diary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.diary-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.diary-preview {
  font-size: 26rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
}

.diary-media-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #aaa;
  display: flex;
  gap: 12rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #bbb;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.empty-create-btn {
  margin-top: 16rpx;
  padding: 20rpx 48rpx;
  background: #4A90E2;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.empty-state-small {
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
  padding: 30rpx 0;
}
