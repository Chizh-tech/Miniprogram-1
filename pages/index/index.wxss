.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #062f57 0%, #0a517b 34%, #14829b 100%);
  padding-bottom: 40rpx;
  position: relative;
}

.ocean-glow {
  position: absolute;
  right: -60rpx;
  top: 110rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(135, 233, 255, 0.42), rgba(135, 233, 255, 0));
}

/* 顶部工具栏 */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(4, 29, 57, 0.62);
  backdrop-filter: blur(4rpx);
}

.view-tabs {
  display: flex;
  background-color: rgba(255, 255, 255, 0.14);
  border-radius: 24rpx;
  overflow: hidden;
}

.tab-item {
  padding: 12rpx 28rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background-color: #c5f3ff;
  color: #0a5d8f;
  font-weight: 500;
  border-radius: 24rpx;
}

.create-btn {
  padding: 14rpx 28rpx;
  background-color: #fff;
  color: #0a5d8f;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 日历容器 */
.calendar-container {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.2);
}

/* 月份导航 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.nav-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #0d7db8;
  font-weight: 300;
}

.month-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.today-btn {
  font-size: 22rpx;
  color: #0d7db8;
  border: 1rpx solid #0d7db8;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: normal;
}

/* 星期表头 */
.week-header {
  display: flex;
  margin-bottom: 12rpx;
}

.status-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  border: 1rpx solid transparent;
}

.legend-icon {
  font-size: 20rpx;
}

.legend-label {
  font-size: 20rpx;
}

.status-detail-box {
  background: #f4fbff;
  border-radius: 12rpx;
  padding: 12rpx;
  margin-bottom: 16rpx;
}

.status-detail-title {
  font-size: 22rpx;
  color: #356b87;
  margin-bottom: 8rpx;
}

.status-detail-item {
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  margin-bottom: 6rpx;
}

.status-detail-item:last-child {
  margin-bottom: 0;
}

.status-detail-text {
  font-size: 22rpx;
  font-weight: 500;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0;
}

/* 日期格子 */
.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 50%;
}

.day-status {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-top: 5rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-status-icon {
  font-size: 14rpx;
  color: #fff;
  line-height: 1;
}

.day-cell.empty {
  pointer-events: none;
}

.day-num {
  font-size: 28rpx;
  color: #333;
  line-height: 1.2;
}

.day-cell.today .day-num {
  color: #0d7db8;
  font-weight: 700;
}

.day-cell.today {
  background-color: #dff4ff;
  border-radius: 50%;
}

.day-cell.selected {
  background-color: #eef7ff;
  border: 2rpx solid #7ab6da;
  border-radius: 50%;
}

.day-cell.selected .day-num {
  color: #0d7db8;
  font-weight: 700;
}

.day-cell.has-diary .day-num {
  color: #0d7db8;
}

.day-cell.status-want .day-num {
  color: #2092d1;
}

.day-cell.status-depart .day-num {
  color: #d4861e;
}

.day-cell.status-diving .day-num {
  color: #2f9a63;
}

.day-cell.status-return .day-num {
  color: #9256c9;
}

.day-cell.selected.status-want .day-num {
  color: #2092d1;
}

.day-cell.selected.status-depart .day-num {
  color: #d4861e;
}

.day-cell.selected.status-diving .day-num {
  color: #2f9a63;
}

.day-cell.selected.status-return .day-num {
  color: #9256c9;
}

.status-default {
  background: #7ea7be;
}

.status-want {
  color: #2092d1;
  background: #e8f7ff;
  border-color: #2092d1;
}

.status-depart {
  color: #d4861e;
  background: #fff4dd;
  border-color: #d4861e;
}

.status-diving {
  color: #2f9a63;
  background: #e9f7ef;
  border-color: #2f9a63;
}

.status-return {
  color: #9256c9;
  background: #f7ecff;
  border-color: #9256c9;
}

.day-status.status-want {
  background: #2092d1;
}

.day-status.status-depart {
  background: #d4861e;
}

.day-status.status-diving {
  background: #2f9a63;
}

.day-status.status-return {
  background: #9256c9;
}

.day-cell.selected .day-status {
  background: rgba(255, 255, 255, 0.95);
}

.day-cell.selected .day-status-icon {
  color: #0d7db8;
}

.month-summary {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

/* 日记列表区域 */
.diary-section {
  padding: 0 24rpx;
}

.section-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 日记卡片 */
.diary-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.diary-card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.diary-date-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  min-width: 80rpx;
  background: #dff4ff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-right: 20rpx;
}

.diary-day {
  font-size: 36rpx;
  font-weight: 700;
  color: #0d7db8;
  line-height: 1.1;
}

.diary-month-year {
  font-size: 20rpx;
  color: #999;
  margin-top: 2rpx;
}

.diary-meta {
  flex: 1;
}

.diary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.diary-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.status-tag {
  border: 1rpx solid transparent;
}

.diary-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 12rpx;
}

.diary-preview {
  font-size: 26rpx;
  color: #666;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.6;
}

.diary-media-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #aaa;
  display: flex;
  gap: 12rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #bbb;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.empty-create-btn {
  margin-top: 16rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(90deg, #1aa5c5, #0d7db8);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.empty-state-small {
  text-align: center;
  color: #ccc;
  font-size: 26rpx;
  padding: 30rpx 0;
}
