.page {
  background-color: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 头部信息卡片 */
.header-info {
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #4A90E2, #6BA3E8);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 226, 0.3);
}

.date-row {
  margin-bottom: 16rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.meta-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-value {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.meta-loading {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.meta-placeholder {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  border-bottom: 1rpx dashed rgba(255, 255, 255, 0.4);
  padding-bottom: 2rpx;
}

/* 调试面板 */
.debug-panel {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.debug-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f2f2f2;
}

.debug-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.debug-toggle {
  font-size: 24rpx;
  color: #4A90E2;
}

.debug-content {
  padding: 12rpx 24rpx 20rpx;
}

.debug-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx dashed #f2f2f2;
}

.debug-row:last-child {
  border-bottom: none;
}

.debug-key {
  flex: 0 0 180rpx;
  font-size: 24rpx;
  color: #666;
}

.debug-value {
  flex: 1;
  font-size: 24rpx;
  color: #222;
  text-align: right;
  word-break: break-all;
}

/* 输入区域 */
.input-section {
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.title-input {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  width: 100%;
  padding: 0;
  margin-bottom: 16rpx;
}

.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin-bottom: 16rpx;
}

.content-input {
  font-size: 28rpx;
  color: #444;
  width: 100%;
  min-height: 300rpx;
  line-height: 1.8;
}

/* 媒体区域 */
.media-section {
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.media-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.media-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.media-count {
  font-size: 24rpx;
  color: #999;
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.media-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
}

.media-thumb {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.video-thumb {
  width: 100%;
  height: 100%;
}

.media-delete {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  line-height: 1;
  text-align: center;
}

.media-add {
  width: 200rpx;
  height: 200rpx;
  background-color: #F5F5F5;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.media-add-icon {
  font-size: 56rpx;
  color: #ccc;
  line-height: 1;
}

.media-add-hint {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.btn-cancel {
  flex: 1;
  margin-right: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.btn-save {
  flex: 2;
  padding: 24rpx 0;
  text-align: center;
  background-color: #4A90E2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-save.disabled {
  background-color: #a0c4f0;
}
