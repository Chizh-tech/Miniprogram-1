<view class="page">
  <view class="ocean-popup-mask" wx:if="{{showOceanAnimalPopup}}" catchtap="closeOceanAnimalPopup">
    <view class="ocean-popup-card" catchtap="preventPopupClose">
      <text class="ocean-popup-title">今日海洋伙伴</text>
      <text class="ocean-popup-icon">{{randomOceanAnimal.icon}}</text>
      <text class="ocean-popup-name">{{randomOceanAnimal.name}}</text>
      <text class="ocean-popup-tip">{{randomOceanAnimal.tip}}</text>
      <view class="ocean-popup-btn" bindtap="closeOceanAnimalPopup">开始记录</view>
    </view>
  </view>

  <!-- 日期和天气位置信息头部 -->
  <view class="header-info card">
    <view class="date-row">
      <text class="date-text">{{dateDisplay}}</text>
    </view>
    <view class="meta-row">
      <!-- 天气 -->
      <view class="meta-item" bindtap="refreshLocationWeather">
        <block wx:if="{{isLoadingWeather}}">
          <text class="meta-loading">⏳ 获取天气中...</text>
        </block>
        <block wx:elif="{{weather}}">
          <text class="meta-value">{{weather.icon}} {{weather.text}} {{weather.temperature}}°C</text>
        </block>
        <block wx:else>
          <text class="meta-placeholder">🌤️ 点击获取天气</text>
        </block>
      </view>

      <!-- 位置 -->
      <view class="meta-item" bindtap="refreshLocationWeather">
        <block wx:if="{{isLoadingLocation}}">
          <text class="meta-loading">⏳ 获取位置中...</text>
        </block>
        <block wx:elif="{{location}}">
          <text class="meta-value">📍 {{location.name}}</text>
        </block>
        <block wx:else>
          <text class="meta-placeholder">📍 点击获取位置</text>
        </block>
      </view>
    </view>
  </view>

  <view class="debug-panel card">
    <view class="debug-header" bindtap="toggleDebugPanel">
      <text class="debug-title">调试面板（位置/天气）</text>
      <text class="debug-toggle">{{showDebugPanel ? '收起' : '展开'}}</text>
    </view>
    <view wx:if="{{showDebugPanel}}" class="debug-content">
      <view class="debug-row"><text class="debug-key">最近刷新</text><text class="debug-value">{{debugInfo.lastRefreshAt}}</text></view>
      <view class="debug-row"><text class="debug-key">位置权限</text><text class="debug-value">{{debugInfo.locationPermission}}</text></view>
      <view class="debug-row"><text class="debug-key">定位状态</text><text class="debug-value">{{debugInfo.locationStatus}}</text></view>
      <view class="debug-row"><text class="debug-key">定位结果</text><text class="debug-value">{{debugInfo.locationResult}}</text></view>
      <view class="debug-row"><text class="debug-key">定位错误</text><text class="debug-value">{{debugInfo.locationError}}</text></view>
      <view class="debug-row"><text class="debug-key">定位原始错误</text><text class="debug-value">{{debugInfo.locationRaw}}</text></view>
      <view class="debug-row"><text class="debug-key">地理编码状态</text><text class="debug-value">{{debugInfo.locationGeocodeStatus}}</text></view>
      <view class="debug-row"><text class="debug-key">地理编码原因</text><text class="debug-value">{{debugInfo.locationGeocodeReason}}</text></view>
      <view class="debug-row"><text class="debug-key">地理编码HTTP</text><text class="debug-value">{{debugInfo.locationGeocodeHttp}}</text></view>
      <view class="debug-row"><text class="debug-key">地理编码API状态</text><text class="debug-value">{{debugInfo.locationGeocodeApiStatus}}</text></view>
      <view class="debug-row"><text class="debug-key">地理编码API消息</text><text class="debug-value">{{debugInfo.locationGeocodeApiMessage}}</text></view>
      <view class="debug-row"><text class="debug-key">地理编码原始错</text><text class="debug-value">{{debugInfo.locationGeocodeRaw}}</text></view>
      <view class="debug-row"><text class="debug-key">天气状态</text><text class="debug-value">{{debugInfo.weatherStatus}}</text></view>
      <view class="debug-row"><text class="debug-key">天气结果</text><text class="debug-value">{{debugInfo.weatherResult}}</text></view>
      <view class="debug-row"><text class="debug-key">天气错误</text><text class="debug-value">{{debugInfo.weatherError}}</text></view>
      <view class="debug-row"><text class="debug-key">天气HTTP状态</text><text class="debug-value">{{debugInfo.weatherHttpStatus}}</text></view>
      <view class="debug-row"><text class="debug-key">天气API返回码</text><text class="debug-value">{{debugInfo.weatherApiCode}}</text></view>
      <view class="debug-row"><text class="debug-key">天气API消息</text><text class="debug-value">{{debugInfo.weatherApiMessage}}</text></view>
      <view class="debug-row"><text class="debug-key">天气原始网络错</text><text class="debug-value">{{debugInfo.weatherRaw}}</text></view>
      <view class="debug-row"><text class="debug-key">天气Key已配置</text><text class="debug-value">{{debugInfo.hasWeatherKey ? '是' : '否'}}</text></view>
      <view class="debug-row"><text class="debug-key">地图Key已配置</text><text class="debug-value">{{debugInfo.hasTencentMapKey ? '是' : '否'}}</text></view>
    </view>
  </view>

  <view class="status-section card">
    <view class="status-title-row">
      <text class="status-title">潜水状态</text>
      <text class="status-tip">请选择当前阶段</text>
    </view>
    <view class="status-options">
      <view
        wx:for="{{diveStatusOptions}}"
        wx:key="value"
        class="status-option {{item.className}} {{diveStatus === item.value ? 'active' : ''}}"
        bindtap="onDiveStatusSelect"
        data-value="{{item.value}}"
      >
        <text class="status-option-icon">{{item.icon}}</text>
        <text class="status-option-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 标题输入 -->
  <view class="input-section card">
    <input
      class="title-input"
      placeholder="潜点标题（选填）"
      placeholder-style="color: #ccc;"
      value="{{title}}"
      bindinput="onTitleInput"
      maxlength="50"
    />
    <view class="divider"></view>
    <!-- 正文输入 -->
    <textarea
      class="content-input"
      placeholder="记录今天看到的海洋生物、能见度、心情和故事..."
      placeholder-style="color: #ccc;"
      value="{{content}}"
      bindinput="onContentInput"
      maxlength="5000"
      auto-height
      show-confirm-bar="{{false}}"
      adjust-position="{{true}}"
    />
    <view class="content-counter">{{content.length}}/5000</view>
  </view>

  <!-- 图片区域 -->
  <view class="media-section card">
    <view class="media-header">
      <text class="media-title">📷 海底照片</text>
      <text class="media-count">{{images.length}}/9</text>
    </view>
    <view class="media-grid">
      <!-- 已选图片 -->
      <view
        wx:for="{{images}}"
        wx:key="index"
        class="media-item"
      >
        <image
          class="media-thumb"
          src="{{imagePreviewUrls[index] || item}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-index="{{index}}"
        />
        <view class="media-delete" catchtap="deleteImage" data-index="{{index}}">×</view>
      </view>

      <!-- 添加图片按钮 -->
      <view
        class="media-add"
        bindtap="chooseImages"
        wx:if="{{images.length < 9}}"
      >
        <text class="media-add-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 视频区域 -->
  <view class="media-section card">
    <view class="media-header">
      <text class="media-title">🎬 潜水视频</text>
      <text class="media-count">{{videos.length}}/3</text>
    </view>
    <view class="media-grid">
      <!-- 已选视频 -->
      <view
        wx:for="{{videos}}"
        wx:key="index"
        class="media-item"
      >
        <video
          class="media-thumb video-thumb"
          src="{{videoPreviewUrls[index] || item}}"
          show-play-btn="{{true}}"
          object-fit="cover"
          enable-play-gesture="{{true}}"
        />
        <view class="media-delete" catchtap="deleteVideo" data-index="{{index}}">×</view>
      </view>

      <!-- 添加视频按钮 -->
      <view
        class="media-add"
        bindtap="chooseVideo"
        wx:if="{{videos.length < 3}}"
      >
        <text class="media-add-icon">+</text>
        <text class="media-add-hint">添加视频</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-actions">
    <view class="btn-cancel" bindtap="onBack">取消</view>
    <view class="btn-save {{isSaving ? 'disabled' : ''}}" bindtap="saveDiary">
      {{isSaving ? '保存中...' : '保存潜水日志'}}
    </view>
  </view>
</view>
