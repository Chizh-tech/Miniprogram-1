/* Global styles */
page {
  background-color: #062F57;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #123b57;
}

.container {
  padding: 20rpx;
}

/* Common button styles */
.btn-primary {
  background: linear-gradient(90deg, #1aa5c5, #0d7db8);
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  border: none;
}

.btn-danger {
  background-color: #E25454;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  border: none;
}

.btn-default {
  background-color: #fff;
  color: #333;
  border-radius: 8rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  border: 1rpx solid #ddd;
}

/* Card styles */
.card {
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* Section title */
.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #ccc;
}

.empty-state text {
  font-size: 28rpx;
  margin-top: 16rpx;
}

/* Tag styles */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background-color: #dff4ff;
  color: #0d7db8;
  margin-right: 8rpx;
}
