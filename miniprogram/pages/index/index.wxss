.container { padding: 20px; display: block; background-color: #fcfcfc; min-height: 100vh; }
.header { font-size: 22px; font-weight: bold; margin-bottom: 25px; color: #333; }
.diary-input { 
  width: 100%; height: 180px; background: #fff; 
  border: 1px solid #ddd; padding: 15px; 
  box-sizing: border-box; border-radius: 12px; 
  margin-bottom: 20px; font-size: 16px;
}
.media-area { 
  width: 100%; height: 200px; background: #f0f0f0; 
  display: flex; align-items: center; justify-content: center; 
  border-radius: 12px; margin-bottom: 25px; overflow: hidden;
  border: 2px dashed #ccc;
}
.preview-img { width: 100%; height: 100%; }
.upload-placeholder { color: #888; font-size: 14px; }
.save-btn { 
  background: #07c160; color: white; 
  border-radius: 25px; font-weight: 500;
  box-shadow: 0 4px 12px rgba(7, 193, 96, 0.2);
  
}

.nav-container {
  margin-top: 30px;
  text-align: center;
  padding-bottom: 40px; /* 留点底部间距，防止太靠下 */
}

.nav-link {
  display: inline-block;
  font-size: 14px;
  color: #576b95; /* 微信经典的蓝色链接色 */
  text-decoration: none;
  padding: 10px 20px;
  border: 1rpx solid #e0e0e0;
  border-radius: 20px;
  background-color: #ffffff;
}