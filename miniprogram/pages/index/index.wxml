<view class="container">
  <view class="header">📅 我的心情日记</view>
  
  <textarea 
    class="diary-input" 
    placeholder="今天发生了什么有趣的事？" 
    bindinput="onInput" 
    value="{{content}}" 
    maxlength="-1" 
  />
  
  <view class="media-area" bindtap="uploadMedia">
    <image wx:if="{{mediaPath}}" src="{{mediaPath}}" mode="aspectFill" class="preview-img"></image>
    <view wx:else class="upload-placeholder">📸 添加照片/视频</view>
  </view>

  <button class="save-btn" bindtap="saveDiary">📁 保存到云端</button>
  <view class="nav-container">
  <navigator url="/pages/history/history" class="nav-link">
    查看我的历史日记 >
  </navigator>
</view>
</view>

